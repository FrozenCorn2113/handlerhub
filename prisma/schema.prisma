// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("POSTGRES_DATABASE_URL")
  directUrl    = env("POSTGRES_DATABASE_URL_UNPOOLED")
  relationMode = "prisma"
}

enum UserRole {
  ADMIN
  EXHIBITOR
  HANDLER
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PROFESSIONAL
}

enum HandlerLevel {
  NEW
  VERIFIED
  PROFESSIONAL
  ELITE
}

enum RequestStatus {
  PENDING
  ACCEPTED
  CONFIRMED
  DECLINED
  COMPLETED
  CANCELLED
}

enum ServiceType {
  HANDLING
  GROOMING
  TRANSPORT
  PHOTOGRAPHY
}

model Account {
  id                       String   @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?  @db.Text
  access_token             String?  @db.Text
  refresh_token_expires_in String?  @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?  @db.Text
  session_state            String?
  createdAt                DateTime @default(now()) @map(name: "created_at")
  updatedAt                DateTime @default(now()) @map(name: "updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map(name: "accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map(name: "sessions")
}

model User {
  id                       String    @id @default(cuid())
  name                     String?
  email                    String?   @unique
  emailVerified            DateTime?
  emailVerificationToken   String?   @unique @map("email_verification_token")
  image                    String?
  password                 String?
  resetPasswordToken       String?   @unique @map("reset_password_token")
  resetPasswordTokenExpiry DateTime? @map("reset_password_token_expiery")

  deletedAt DateTime?
  isBlocked Boolean   @default(false)

  role UserRole @default(EXHIBITOR)

  isTwoFactorEnabled    Boolean                @default(false)
  twoFactorConfirmation TwoFactorConfirmation?

  createdAt DateTime @default(now()) @map(name: "created_at")
  updatedAt DateTime @default(now()) @map(name: "updated_at")

  accounts      Account[]
  sessions      Session[]
  // Optional for WebAuthn support
  Authenticator Authenticator[]

  stripeCustomerId       String?   @unique @map(name: "stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map(name: "stripe_subscription_id")
  stripePriceId          String?   @map(name: "stripe_price_id")
  stripeCurrentPeriodEnd DateTime? @map(name: "stripe_current_period_end")

  // HandlerHub relationships
  handlerProfile          HandlerProfile?
  dogProfiles             DogProfile[]      @relation("DogProfiles")
  bookingRequestsSent     BookingRequest[]  @relation("ExhibitorRequests")
  bookingRequestsReceived BookingRequest[]  @relation("HandlerRequests")
  reviewsGiven            Review[]          @relation("ExhibitorReviews")
  reviewsReceived         Review[]          @relation("HandlerReviews")
  conversations           Conversation[]    @relation("ConversationParticipants")
  messagesSent            Message[]
  serviceRequests         ServiceRequest[]
  handlerResponses        RequestResponse[] @relation("HandlerResponses")
  disputes                Dispute[]         @relation("disputes")
  handlerServices         HandlerService[]  @relation("handlerServices")
  showAttendance          HandlerShowAttendance[] @relation("showAttendance")

  @@map(name: "users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// Optional for WebAuthn support
model Authenticator {
  id                   String  @id @default(cuid())
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model TwoFactorConfirmation {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
}

// HandlerHub specific models
model HandlerProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Basic info
  fullName        String?
  businessName    String?
  bio             String?   @db.Text
  yearsExperience Int?
  experienceLevel ExperienceLevel @default(INTERMEDIATE)

  // Contact & Location
  contactEmail  String?
  contactPhone  String?
  website       String?
  facebook      String?
  instagram     String?
  city          String?
  state         String?
  country       String    @default("USA")
  latitude      Float?    // Geocoded from city/state
  longitude     Float?    // Geocoded from city/state
  regions       String[]  // Array of regions they serve (e.g., ["Pacific Northwest", "California", "Western US"])
  travelWillingness String[] // ["Local", "Regional", "National", "International"]

  // Specializations
  breeds        String[]  // Array of breed names they specialize in
  services      String[]  // Array of services (e.g., ["Conformation Handling", "Professional Handling", "Grooming", "Training"])
  serviceTypes  ServiceType[] @default([HANDLING])

  // Pricing & Availability
  ratePerShow   Float?    // Rate per show in USD
  ratePerDay    Float?    // Rate per day in USD
  priceRange    String?   // e.g., "$$" or "$100-$200/show"
  feeRangeMin   Float?    // Minimum fee
  feeRangeMax   Float?    // Maximum fee
  availability  String?   @db.Text // Free text for availability description
  availabilityScheduleLink String? // Link to Calendly or other scheduling tool
  isAvailable   Boolean   @default(true)
  preferredContactMethod String? // "Email", "Phone", "Text", "Facebook Messenger"

  // Portfolio & Proof
  showHighlights String?  @db.Text // Westminster finalist, AKC Group Winner, etc.
  pastClients    String?  @db.Text // Past clients or kennels worked with
  handlerResume  String?  @db.Text // Detailed resume/bio

  // Trust & Verification
  isInsured         Boolean  @default(false)
  isBonded          Boolean  @default(false)
  referencesAvailable Boolean @default(false)
  kennelClubMemberships String[] // ["AKC", "CKC", "UKC", etc.]

  // Automated Handler Level System (Fiverr-style)
  handlerLevel            HandlerLevel @default(NEW)
  totalCompletedBookings  Int          @default(0)
  averageRating           Float?       // Calculated from reviews
  responseRate            Float?       // % of requests responded to within 24hrs
  profileCompleteness     Float?       // % of profile fields filled (0-100)
  lastLevelUpAt           DateTime?
  levelUpEligibleAt       DateTime?

  // Media
  profileImage  String?
  coverImage    String?
  galleryImages String[]

  // Stats
  viewCount     Int       @default(0)
  featured      Boolean   @default(false)

  // Fee schedule & registries
  feeSchedule Json?
  registries  String[]

  // Cancellation policy
  cancellationPolicy String?

  // Terms acceptance
  agreedToTerms Boolean   @default(false)
  termsAgreedAt DateTime?

  // Claiming
  isClaimed   Boolean   @default(true)
  claimedAt   DateTime?
  claimedBy   String?   // userId who claimed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([city, state])
  @@index([isAvailable])
  @@map("handler_profiles")
}

model DogProfile {
  id     String @id @default(cuid())
  userId String

  // Basic Information
  name   String
  breed  String
  sex    String  // "Male", "Female"
  age    Int     // Age in years

  // Registration & Titles
  registeredName String?  @db.Text // Official AKC/registered name
  titles         String?  @db.Text // CH, GCH, GCHB, etc.
  achievements   String?  @db.Text // Major wins, accomplishments

  // Experience & Behavior
  showExperience String   @default("FIRST_TIMER") // "FIRST_TIMER", "BEGINNER", "INTERMEDIATE", "VETERAN"
  temperament    String?  @db.Text // Behavior notes for handlers
  specialNeeds   String?  @db.Text // Medication, grooming quirks, allergies, etc.

  // Preferences
  preferredHandlerTraits String? @db.Text // e.g., "female only", "breed specialist"

  // Schedule & Shows
  upcomingShows  String?  @db.Text // Upcoming show schedule

  // Media
  photos         String[] // Array of photo URLs

  // Metadata
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  owner          User     @relation("DogProfiles", fields: [userId], references: [id], onDelete: Cascade)
  bookingRequests BookingRequest[]

  @@index([userId])
  @@index([breed])
  @@map("dog_profiles")
}

model BookingRequest {
  id String @id @default(cuid())

  // Parties involved
  exhibitorId String
  handlerId   String
  dogProfileId String? // Optional - links to a saved dog profile

  // Show details
  showName     String
  showLocation String
  showDate     DateTime

  // Dog details (can be from profile or entered manually)
  dogBreed     String
  dogName      String?

  // Request details
  message      String    @db.Text
  status       RequestStatus @default(PENDING)

  // Additional booking details
  classEntries           String[]
  travelRequirements     String?   @db.Text
  priorHandlerExperience String?
  eventId                String?

  // Handler response tracking
  handlerNotes String?   @db.Text
  handlerResponded Boolean @default(false)
  respondedAt  DateTime?
  completedAt  DateTime? // When booking was marked COMPLETED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exhibitor    User          @relation("ExhibitorRequests", fields: [exhibitorId], references: [id], onDelete: Cascade)
  handler      User          @relation("HandlerRequests", fields: [handlerId], references: [id], onDelete: Cascade)
  dogProfile   DogProfile?   @relation(fields: [dogProfileId], references: [id], onDelete: SetNull)
  review       Review?
  conversation Conversation?
  services     BookingService[]
  disputes     Dispute[]

  @@index([exhibitorId])
  @@index([handlerId])
  @@index([dogProfileId])
  @@index([status])
  @@index([showDate])
  @@map("booking_requests")
}

model Review {
  id String @id @default(cuid())

  // Booking this review is for (one review per booking)
  bookingRequestId String @unique

  // Reviewer (exhibitor) and reviewee (handler)
  exhibitorId String
  handlerId   String

  // Review content
  rating  Int    // 1-5 stars
  comment String @db.Text

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookingRequest BookingRequest @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  exhibitor      User           @relation("ExhibitorReviews", fields: [exhibitorId], references: [id], onDelete: Cascade)
  handler        User           @relation("HandlerReviews", fields: [handlerId], references: [id], onDelete: Cascade)

  @@index([bookingRequestId])
  @@index([exhibitorId])
  @@index([handlerId])
  @@index([rating])
  @@map("reviews")
}

model Conversation {
  id String @id @default(cuid())

  // Link to booking request this conversation is about (optional for direct messaging)
  bookingRequestId String? @unique

  // Participant IDs (exhibitor and handler)
  participantIds String[] // Array of user IDs

  // Metadata
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookingRequest  BookingRequest?  @relation(fields: [bookingRequestId], references: [id], onDelete: Cascade)
  participants    User[]           @relation("ConversationParticipants")
  messages        Message[]
  requestResponse RequestResponse?

  @@index([bookingRequestId])
  @@map("conversations")
}

model Message {
  id String @id @default(cuid())

  conversationId String
  senderId       String

  content String @db.Text

  // Read tracking
  readAt DateTime?

  // Timestamps
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([senderId])
  @@index([sentAt])
  @@map("messages")
}

model ServiceRequest {
  id           String    @id @default(cuid())
  title        String
  description  String
  breed        String?
  akcGroup     String?
  showName     String?
  showDate     DateTime?
  showLocation String?
  serviceType  String    // HANDLING, GROOMING, TRANSPORT, OTHER
  region       String?
  status       String    @default("OPEN") // OPEN, FILLED, EXPIRED, FLAGGED
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  responses    RequestResponse[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([serviceType])
  @@map("service_requests")
}

model RequestResponse {
  id             String          @id @default(cuid())
  requestId      String
  request        ServiceRequest  @relation(fields: [requestId], references: [id])
  handlerId      String
  handler        User            @relation("HandlerResponses", fields: [handlerId], references: [id])
  message        String
  conversationId String?         @unique
  conversation   Conversation?   @relation(fields: [conversationId], references: [id])
  createdAt      DateTime        @default(now())

  @@index([requestId])
  @@index([handlerId])
  @@index([conversationId])
  @@map("request_responses")
}

// ──────────────────────────────────────────────
// AKC Events Feature
// ──────────────────────────────────────────────

model Venue {
  id               String   @id @default(cuid())
  name             String
  normalizedName   String   // lowercased, stripped for matching
  address          String
  normalizedAddress String  // lowercased, standardized for "also at this venue"
  city             String
  state            String
  latitude         Float?
  longitude        Float?
  indoorOutdoor    String?  // "Indoors", "Outdoors", or null
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  events Event[]

  @@unique([normalizedAddress])
  @@index([state])
  @@index([city, state])
  @@index([latitude, longitude])
  @@map("venues")
}

enum EventType {
  ALL_BREED        // AB
  LIMITED_BREED     // LB
  SPECIALTY         // S
  PARENT_SPECIALTY  // PS
  DESIGNATED_SPECIALTY // DS
  JUNIOR_SHOWMANSHIP // JSHW
  SWEEPSTAKES       // SWPC
  OTHER
}

enum EntryStatus {
  NOT_YET_OPEN
  OPEN
  CLOSING_SOON
  CLOSED
}

model Event {
  id           String    @id @default(cuid())
  slug         String    @unique

  // AKC data
  clubName     String
  eventNumber  String
  eventType    EventType
  eventTypeRaw String    // Original code from CSV (S, AB, LB, etc.)
  startDate    DateTime
  startDay     String?   // "Monday", "Tuesday", etc.

  // Entry info
  entryAcceptanceMethod String?
  entryLimit            String?
  openingDay            String?
  openingDateTime       DateTime?
  closingDay            String?
  closingDateTime       DateTime?
  timeZone              String?
  entryStatus           EntryStatus @default(OPEN)
  entryFee              String?

  // Contacts
  superintendentName    String?
  superintendentPhone   String?
  superintendentEmail   String?
  eventChairName        String?
  eventChairPhone       String?
  eventChairEmail       String?

  // Breeds
  eligibleBreeds        String?

  // Venue relation
  venueId      String
  venue        Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Attendance
  handlerAttendance HandlerShowAttendance[]

  // Metadata
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([venueId])
  @@index([startDate])
  @@index([eventType])
  @@index([entryStatus])
  @@index([clubName])
  @@index([startDate, eventType])
  @@index([startDate, entryStatus])
  @@index([venueId, startDate])
  @@map("events")
}

// ──────────────────────────────────────────────
// Disputes
// ──────────────────────────────────────────────

model Dispute {
  id          String   @id @default(cuid())
  bookingId   String
  reporterId  String
  reason      String
  status      String   @default("OPEN")
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  booking     BookingRequest @relation(fields: [bookingId], references: [id])
  reporter    User     @relation("disputes", fields: [reporterId], references: [id])

  @@index([bookingId])
  @@index([reporterId])
  @@index([status])
  @@map("disputes")
}

// ──────────────────────────────────────────────
// Handler Services (itemized pricing)
// ──────────────────────────────────────────────

model HandlerService {
  id          String   @id @default(cuid())
  handlerId   String
  name        String
  description String?
  price       Int
  pricePer    String
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  handler     User     @relation("handlerServices", fields: [handlerId], references: [id], onDelete: Cascade)
  bookings    BookingService[]

  @@index([handlerId])
  @@index([isActive])
  @@map("handler_services")
}

model BookingService {
  id               String         @id @default(cuid())
  bookingId        String
  handlerServiceId String
  quantity         Int            @default(1)
  priceAtBooking   Int
  booking          BookingRequest @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  handlerService   HandlerService @relation(fields: [handlerServiceId], references: [id])

  @@unique([bookingId, handlerServiceId])
  @@index([bookingId])
  @@index([handlerServiceId])
  @@map("booking_services")
}

// ──────────────────────────────────────────────
// Handler Show Attendance
// ──────────────────────────────────────────────

model HandlerShowAttendance {
  id        String   @id @default(cuid())
  handlerId String
  eventId   String
  maxDogs   Int?
  notes     String?
  createdAt DateTime @default(now())
  handler   User     @relation("showAttendance", fields: [handlerId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@unique([handlerId, eventId])
  @@index([handlerId])
  @@index([eventId])
  @@map("handler_show_attendance")
}
